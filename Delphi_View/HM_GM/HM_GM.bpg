#------------------------------------------------------------------------------
VERSION = BWS.01
#------------------------------------------------------------------------------
!ifndef ROOT
ROOT = $(MAKEDIR)\..
!endif
#------------------------------------------------------------------------------
MAKE = $(ROOT)\bin\make.exe -$(MAKEFLAGS) -f$**
DCC = $(ROOT)\bin\dcc32.exe $**
BRCC = $(ROOT)\bin\brcc32.exe $**
#------------------------------------------------------------------------------
PROJECTS = HM_GM_CP.exe HM_GB_BZ.exe HM_GM_CR.exe
#------------------------------------------------------------------------------
default: $(PROJECTS)
#------------------------------------------------------------------------------


HM_GM_CP.exe: HM_GM_CP\HM_GM_CP.dpr
  $(DCC)

HM_GB_BZ.exe: ..\HM_GB\HM_GB_BZ\HM_GB_BZ.dpr
  $(DCC)

HM_GM_CR.exe: HM_GM_CR\HM_GM_CR.dpr
  $(DCC)


