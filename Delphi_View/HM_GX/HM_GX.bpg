#------------------------------------------------------------------------------
VERSION = BWS.01
#------------------------------------------------------------------------------
!ifndef ROOT
ROOT = $(MAKEDIR)\..
!endif
#------------------------------------------------------------------------------
MAKE = $(ROOT)\bin\make.exe -$(MAKEFLAGS) -f$**
DCC = $(ROOT)\bin\dcc32.exe $**
BRCC = $(ROOT)\bin\brcc32.exe $**
#------------------------------------------------------------------------------
PROJECTS = HM_GX_EX.exe HM_GX_RS.exe HM_GB_BZ.exe HM_GR_RV.exe COOO.exe \
  HM_GM_CR.exe HM_GS_RC.exe HM_GZ_CD.exe
#------------------------------------------------------------------------------
default: $(PROJECTS)
#------------------------------------------------------------------------------


HM_GX_EX.exe: HM_GX_EX\HM_GX_EX.dpr
  $(DCC)

HM_GX_RS.exe: HM_GX_RS\HM_GX_RS.dpr
  $(DCC)

HM_GB_BZ.exe: ..\HM_GB\HM_GB_BZ\HM_GB_BZ.dpr
  $(DCC)

HM_GR_RV.exe: ..\HM_GR\HM_GR_RV\HM_GR_RV.dpr
  $(DCC)

COOO.exe: Z:\홍수연\화면설계서\델파이\처방\COOO\COOO.dpr
  $(DCC)

HM_GM_CR.exe: ..\HM_GM\HM_GM_CR\HM_GM_CR.dpr
  $(DCC)

HM_GS_RC.exe: ..\HM_GS\HM_GS_RC\HM_GS_RC.dpr
  $(DCC)

HM_GZ_CD.exe: ..\HM_GZ\HM_GZ_CD\HM_GZ_CD.dpr
  $(DCC)


